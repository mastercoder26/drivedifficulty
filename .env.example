# Google Cloud API key with Routes API and Roads API enabled
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Comma-separated allowed CORS origins (use * for MVP)
ALLOWED_ORIGINS=*

# Supabase (optional — prediction logging and feedback loop)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Live route conditions (optional)
# Weather comes from Open-Meteo (free, no key required).
# Road metadata (size, class, surface, construction, turn protection) comes
# from OpenStreetMap via the Overpass API. Override the endpoint if you run
# your own instance or want a different public mirror.
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter
# Set to 1 to skip all live-condition lookups (weather + OSM)
# DISABLE_ENRICHMENT=0
