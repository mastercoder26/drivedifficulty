{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/route/difficulty",
      "dest": "/api/route/difficulty.ts"
    },
    {
      "src": "/api/route/feedback",
      "dest": "/api/route/feedback.ts"
    }
  ]
}
